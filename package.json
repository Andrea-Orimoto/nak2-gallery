{
  "name": "icloud-album-gallery",
  "version": "1.0.0",
  "description": "Static gallery for iCloud shared album with filtering, tags, and search",
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./tailwind.css --watch",
    "update": "node scripts/update-index.js",
    "dev": "echo 'Open public/index.html directly in browser'"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "icloud-shared-album": "^1.2.0"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
